# Secrets — never commit
.env
gitkey.md

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Node
node_modules/
npm-debug.log*
frontend/build/

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/
*.egg

# IDE
.vscode/
.idea/

# Docker
*.log

# SQLite journal/WAL files (transient, not needed in git)
*.db-shm
*.db-wal

# NCUA raw ZIP download cache (regenerated by ncua_ingest.py — not needed in git)
backend/data/ncua_raw/

# NCUA API response cache (regenerated at runtime)
backend/data/ncua_cache/

# NOTE: backend/data/ncua_callreports.db is intentionally NOT ignored.
# At ~24 MB it is safe to commit and lets Render serve data immediately
# without running the ingest script on first deploy.
